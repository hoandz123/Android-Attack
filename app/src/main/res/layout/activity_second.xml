<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/second_title"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/second_hint"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/second_counter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:text="@string/second_counter_initial"
        android:textSize="22sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btn_tap_zone"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        android:backgroundTint="#4CAF50"
        android:text="@string/btn_tap_zone"
        android:textSize="16sp" />

    <Button
        android:id="@+id/btn_second_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/btn_second_action" />

    <EditText
        android:id="@+id/second_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="@string/second_input_hint"
        android:inputType="text" />

    <Button
        android:id="@+id/btn_back"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/btn_back" />

    <TextView
        android:id="@+id/second_touch_log"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="#1A000000"
        android:padding="8dp"
        android:text="@string/touch_log_initial"
        android:textIsSelectable="true"
        android:textSize="11sp"
        android:typeface="monospace" />

</LinearLayout>
